[Unit]
Description=Nomad Screen media server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/nomadscreen
Environment=NOMADSCREEN_STORAGE_ROOT=/srv/nomadscreen
Environment=NOMADSCREEN_PORT=80
ExecStart=/usr/bin/python3 /opt/nomadscreen/src/main.py
Restart=on-failure
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
