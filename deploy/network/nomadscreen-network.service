[Unit]
Description=Backcountry Broadcast Wi-Fi fallback
Wants=NetworkManager.service
After=NetworkManager.service
Before=nomadscreen.service

[Service]
Type=oneshot
Environment=NOMADSCREEN_STORAGE_ROOT=/srv/nomadscreen
ExecStart=/opt/nomadscreen/deploy/network/nomadscreen-network.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
